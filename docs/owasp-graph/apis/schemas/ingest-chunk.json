{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencre.org/schemas/oie/ingest-chunk.json",
  "title": "IngestChunk",
  "type": "object",
  "additionalProperties": false,
  "required": ["chunk_id", "text", "char_count", "span"],
  "properties": {
    "chunk_id": { "type": "string", "minLength": 8 },
    "text": { "type": "string", "minLength": 1 },
    "char_count": { "type": "integer", "minimum": 1 },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "total"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "heading_path": {
          "type": "array",
          "items": { "type": "string" }
        },
        "start_char_idx": { "type": "integer", "minimum": 0 },
        "end_char_idx": { "type": "integer", "minimum": 0 },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text_before": { "type": "string" }
      }
    }
  }
}
